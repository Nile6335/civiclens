# CivicLens configuration.
# `make setup` copies this to .env if .env does not exist.
#
# The defaults below are the LEAN profile: small, ungated, CPU-friendly models so
# `make demo` works on modest hardware (tested on an 8GB M-series Mac with <5GB free disk).
# The spec-scale profile (llama3.1:8b, bge-m3, bge-reranker-base, bart-large-mnli) is
# commented next to each knob — flip them if you have ~10GB of disk and 16GB+ RAM.

# --- Database ---
DATABASE_URL=postgresql://civiclens:civiclens@localhost:5442/civiclens

# --- LLM backend: ollama (default, free, local) or anthropic (if you have a key) ---
LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b
# OLLAMA_MODEL=llama3.1:8b            # spec-scale (needs ~5GB disk, 8GB+ free RAM)
ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=                  # only used when LLM_BACKEND=anthropic

# --- Embeddings (sentence-transformers model + its output dimension) ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
# EMBEDDING_MODEL=BAAI/bge-m3         # spec-scale (2.3GB download)
# EMBEDDING_DIM=1024

# --- Reranker (cross-encoder) ---
RERANKER_MODEL=cross-encoder/ms-marco-TinyBERT-L-2-v2
# RERANKER_MODEL=BAAI/bge-reranker-base   # spec-scale (1.1GB download)

# --- Topic tagging: keyword (no download) or zeroshot (HF zero-shot pipeline) ---
TOPIC_TAGGER=keyword
ZERO_SHOT_MODEL=facebook/bart-large-mnli   # used only when TOPIC_TAGGER=zeroshot (1.6GB)

# --- Langfuse (self-hosted; keys match LANGFUSE_INIT_* in infra/docker-compose.yml) ---
LANGFUSE_HOST=http://localhost:3002
LANGFUSE_PUBLIC_KEY=pk-lf-civiclens-dev
LANGFUSE_SECRET_KEY=sk-lf-civiclens-dev

# --- Service ports/hosts ---
API_HOST=127.0.0.1
API_PORT=8000
